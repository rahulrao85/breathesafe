# BreatheSafe - environment variables
# Copy to .env (do NOT commit) and fill in for local dev.
# For Cloud Run: set these in the service config, never in the image.

# --- Required for Cloud Run deployment ---
# GCP project that owns BigQuery, Cloud Storage, Vertex AI, and Cloud Run
BQ_PROJECT_ID=breathesafe-hackathon
GCP_PROJECT_ID=breathesafe-hackathon

# Region for the Cloud Run service + BigQuery dataset + Vertex AI
GCP_REGION=asia-south1

# Path inside the container to a service-account key with
# BigQuery Data Viewer, BigQuery Job User, Storage Object Viewer, and
# Vertex AI User scopes. On Cloud Run prefer Workload Identity instead
# of mounting a key.
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa.json

# --- Optional: Vertex AI model override ---
# If unset, defaults to gemini-2.5-flash (broadly available in asia-south1).
# Switch to gemini-2.5-pro if your region supports it (check Vertex AI model
# availability in your region).
VERTEX_MODEL=gemini-2.5-flash

# --- Optional: switch from local CSV fallback to live BigQuery ---
# When true, /api/districts and /api/summary read from BigQuery.
# When false (default), the processed CSVs ship inside the image.
USE_BIGQUERY=false
